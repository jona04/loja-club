# Template for the environment. Copy to .env and fill real values.
# NEVER commit .env (it is gitignored). Real secrets live only in your local
# .env or a secret store (GitHub Actions Secrets / AWS SSM in deploy).

# Domain (dev). Subdomains (*.localhost) resolve to 127.0.0.1 in browsers;
# use /etc/hosts for CLI tools. Production sets this via env (loja.club).
DOMAIN=localhost

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5180

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Loja Club"
STACK_NAME=loja-club

# Platform defaults (each store/customer sets its own).
PLATFORM_DEFAULT_CURRENCY=USD
PLATFORM_DEFAULT_LOCALE=en-US

# Backend
BACKEND_CORS_ORIGINS="http://localhost:5180,http://localhost,https://localhost,http://app.localhost:8088,http://admin.localhost:8088"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@loja.club
FIRST_SUPERUSER_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Object storage (AWS S3 + CloudFront) — região us-east-2 (Ohio), 1ª etapa.
# Preencher no .env local após provisionar a AWS dev (P2-MEDIA-01).
S3_REGION=us-east-2
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_BASE_URL=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=loja-club-backend
DOCKER_IMAGE_FRONTEND=loja-club-frontend
DOCKER_IMAGE_STOREFRONT=loja-club-storefront
