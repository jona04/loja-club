# Domain (dev). Subdomains (*.loja.localhost) resolve to 127.0.0.1 in browsers;
# use /etc/hosts for CLI tools. Production sets this via env (loja.club).
DOMAIN=loja.localhost

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5180
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Loja Club"
STACK_NAME=loja-club

# Platform defaults (each store/customer sets its own).
PLATFORM_DEFAULT_CURRENCY=USD
PLATFORM_DEFAULT_LOCALE=en-US

# Backend
BACKEND_CORS_ORIGINS="http://localhost:5180,http://localhost,https://localhost,http://app.loja.localhost:8088,http://admin.loja.localhost:8088"
